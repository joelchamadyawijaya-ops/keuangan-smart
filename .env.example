# Environment Configuration
# Copy this file to .env and fill in your values

# Node.js
NODE_ENV=development
PORT=3000

# JWT Secret
JWT_SECRET=fintechsecret

# Python AI Server
PYTHON_PORT=5000

# Database (untuk production)
DATABASE_URL=
DATABASE_USER=
DATABASE_PASSWORD=

# API Keys
EXCHANGERATE_API_KEY=

# Logging
LOG_LEVEL=info
